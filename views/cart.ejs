<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cart</title>
    <link rel="stylesheet" href="styles.css/cart.css">
    <link rel="stylesheet" href="https://pro.fontawesome.com/releases/v5.10.0/css/all.css" />
</head>

<body>
    <%- include('./partials/nav.ejs') %>


    <h1 class="cart-title"><i class="far fa-shopping-bag"></i> Your Cart</h1>
    <h4 class="cart-title">
        <p class="item-quantity">1</p> items at checkout
    </h4>

    <div class="main-page">
        <section class="left-sec">
            <div class="free-ship">
                <div id="free-ship-div">You're <p id="money-left">9 </p> items away from FREE SHIPPING!</div>
                <a href="shop.html">Continue Shopping!</a>
            </div>
            <hr class="hrr">
        
            <section>
                    <% products.forEach(product => { %>
                        <a href="/details/<%= product._id %>" class="item">
                            <div class="item-img"><img src="<%= product.image %>" alt=""></div>
                            <div class="item-details">
                                <p class="item-name"><%= product.name%></p>
                                <div>
                                    <p class="item-quantity"><%= product.qty%></p> item(s)
                                    <br>
                                    <br>
                                    <span>$</span><span id="item-price"><%= product.price%></span>
                                </div>
                                <!-- <div class="item-adder">
                                    <button id="sub" onclick="sub()">-</button>
                                    <p class="item-quantity">1</p>
                                    <button id="add" onclick="add()">+</button>
                                </div> -->
                            </div>
                        </a>
                    <% }) %>
            </section>
            <hr class="hrr">
        </section>

        <section class="right-sec">
            <h3>Summary</h3>
            <br>
            <div class="subtotal">
                <p><span>Subtotal</span><span class="price">$</span></p>
                <p><span>Discount</span> <span id="check">-$0</span></p>
                <hr>
            </div>
            <div class="total">
                <h3><span>Total</span><span>$</span></h3>
                <form onsubmit="checkPromo(); return false;">
                    <input type="text" placeholder="Enter promo code" class="promo-input">
                    <button type="submit" class="promo-btn">Apply</button>
                  </form>
                <button class="btn">Checkout</button>
            </div>
        </section>


    </div>
    <%- include('./partials/footer.ejs') %>
    <script src="./scripts/cart.js"></script>
    <script src="./scripts/darkMode.js"></script>

</body>

</html>